# Dependencias
/vendor/

# Archivos subidos por usuarios (NO versionar)
/public/uploads/
/public/uploads/**

# Imagenes y fotos de carga de usuarios
/public/uploads/**/*.jpg
/public/uploads/**/*.jpeg
/public/uploads/**/*.png
/public/uploads/**/*.gif
/public/uploads/**/*.webp
/public/uploads/**/*.avif
/public/uploads/**/*.bmp

# Mantener carpetas vacias versionables cuando se use .gitkeep
!/public/uploads/**/.gitkeep

# Credenciales de base de datos (cada entorno tiene las suyas)
# Copiar config/database.example.php → config/database.php y rellenar
config/database.php

# ignorar htaccess local de desarrollo
# .htaccess   <-- descomentado: el .htaccess de produccion ya esta listo en el repo
